# Public Supabase config used by browser and server helpers.
NEXT_PUBLIC_SUPABASE_URL=https://kdhsdsadeoeggfagrdio.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only key used to scaffold and load portal profiles.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google auth for NextAuth/Auth.js.
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Required for signed JWT sessions in production.
AUTH_SECRET=replace-with-a-long-random-secret

# Helpful for local auth callback URLs.
NEXTAUTH_URL=http://localhost:3000
